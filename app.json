{
  "expo": {
    "name": "MAURI-KILCHI",
    "slug": "maurikilchi-app",
    "version": "1.1.3",
    "runtimeVersion": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/main_logo_backup.png",
    "scheme": "maurikilchi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash_blank.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maurikilchi.marketplace",
      "buildNumber": "5",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Maurikilchi utilise votre position pour afficher les livreurs proches de vous.",
        "NSLocationAlwaysUsageDescription": "Maurikilchi utilise votre position pour afficher les livreurs proches de vous."
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBGwboYBZ9gTj8hF2dWSLvT4JyMPAEoIpI"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/main_logo_padded.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.maurikilchi.marketplace",
      "versionCode": 5,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amazon-Ember-Regular.ttf",
            "./assets/fonts/Amazon-Ember-Medium.ttf",
            "./assets/fonts/Amazon-Ember-Bold.ttf",
            "./assets/fonts/Amazon-Ember-Mono.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFDF5",
          "image": "./assets/images/splash_blank.png",
          "imageWidth": 1,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ce4f04b-ed45-4e54-b2bd-9d7d15eb19c4"
      }
    },
    "owner": "arabytes01"
  }
}
