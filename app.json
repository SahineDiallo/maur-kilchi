{
  "expo": {
    "name": "Maurikilchi",
    "slug": "maurikilchi-app",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/main_logo.png",
    "scheme": "maurikilchi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8AC12"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maurikilchi.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Maurikilchi utilise votre position pour afficher les livreurs proches de vous.",
        "NSLocationAlwaysUsageDescription": "Maurikilchi utilise votre position pour afficher les livreurs proches de vous."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/main_logo_white.png",
        "backgroundColor": "#F8AC12"
      },
      "package": "com.maurikilchi.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amazon-Ember-Regular.ttf",
            "./assets/fonts/Amazon-Ember-Medium.ttf",
            "./assets/fonts/Amazon-Ember-Bold.ttf",
            "./assets/fonts/Amazon-Ember-Mono.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8AC12",
          "image": "./assets/images/splash.png",
          "imageWidth": 300,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50a03d41-2934-49f3-8926-4c6e86eae05a"
      }
    }
  }
}
