{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios":     { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios":     { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://maurikilchi.com"
      }
    },
    "production": {
      "distribution": "store",
      "android": { "buildType": "app-bundle" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://maurikilchi.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
